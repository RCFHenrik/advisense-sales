# ── Advisense Sales Orchestration — Environment Template ───────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# App
DEBUG=false

# Database
# SQLite (local dev):
DATABASE_URL=sqlite:///./database/sales_support.db
# PostgreSQL (Azure):
# DATABASE_URL=postgresql://user:password@host:5432/sales_support

# JWT Authentication — CHANGE THIS IN PRODUCTION!
SECRET_KEY=CHANGE-ME-TO-A-RANDOM-64-CHAR-STRING
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=https://sales.advisense.com

# Microsoft Graph API (Outlook integration)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Rate limiting
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# AI Presentation Analysis
ANTHROPIC_API_KEY=
